OPENAI_API_KEY=colocar_api_key_aqui
OPENAI_MODEL=gpt-4o-mini

# String de conexion ODBC completo para SQL Server
# Reemplaza SERVER, DATABASE, UID y PWD con tus valores reales de Azure SQL
SQLSERVER_ODBC=DRIVER={ODBC Driver 18 for SQL Server};SERVER=tiara-sql-server.database.windows.net,1433;DATABASE=TiaraDemo;UID=tiara_admin;PWD=colocar_password_aqui;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=30;

CHROMA_COLLECTION=vanna_tool_memory
SCHEMA_COLLECTION=tiara_schema
